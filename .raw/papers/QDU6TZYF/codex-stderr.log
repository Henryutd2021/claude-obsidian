from pathlib import Path
import re,zlib
p=Path('/Users/henry/Library/CloudStorage/OneDrive-TheUniversityofTexasatDallas/Zotero/Kikstra et al_2021_Climate mitigation scenarios with persistent COVID-19-related energy demand.pdf')
out_path=Path('/tmp/qdu6tzyf_fulltext.txt')
data=p.read_bytes()

def pdf_string(s: bytes) -> str:
    res=[]; i=0
    while i < len(s):
        b=s[i]
        if b==92:  # backslash
            i+=1
            if i>=len(s): break
            c=s[i]
            maps={ord('n'):'\\n',ord('r'):'\\r',ord('t'):'\\t',ord('b'):'\\b',ord('f'):'\\f',ord('('):'(',ord(')'):')',ord('\\\\'):'\\\\'}
            if c in maps:
                res.append(maps[c]); i+=1
            elif 48 <= c <= 55:
                octal=bytes([c]); i+=1
                for _ in range(2):
                    if i < len(s) and 48 <= s[i] <= 55:
                        octal += bytes([s[i]]); i+=1
                    else:
                        break
                res.append(chr(int(octal,8)))
            elif c in (10,13):
                while i < len(s) and s[i] in (10,13): i+=1
            else:
                res.append(chr(c)); i+=1
        else:
            res.append(chr(b)); i+=1
    return ''.join(res)

def extract_strings(stream: bytes):
    strings=[]; i=0; n=len(stream)
    while i<n:
        if stream[i]==40:  # (
            i+=1; start=i; depth=1; buf=bytearray(); esc=False
            while i<n and depth>0:
                b=stream[i]
                if esc:
                    buf.append(92); buf.append(b); esc=False; i+=1; continue
                if b==92:
                    esc=True; i+=1; continue
                if b==40:
                    depth+=1; buf.append(b); i+=1; continue
                if b==41:
                    depth-=1
                    if depth==0:
                        i+=1; break
                    buf.append(b); i+=1; continue
                buf.append(b); i+=1
            strings.append(pdf_string(bytes(buf)))
        elif stream[i:i+2] in (b'Td', b'TD') or stream[i:i+2] == b'T*':
            strings.append('\\n')
            i+=2
        else:
            i+=1
    return strings

pages=[]
for m in re.finditer(rb'stream\\r?\\n', data):
    start=m.end(); end=data.find(b'endstream', start)
    if end<0: continue
    raw=data[start:end].strip(b'\\r\\n')
    for candidate in (raw, raw[:-1]):
        try:
            dec=zlib.decompress(candidate)
            break
        except Exception:
            dec=None
    if dec is None: continue
    txt=''.join(extract_strings(dec))
    txt=txt.replace('\\x00','')
    txt=re.sub(r'[ \\t]+',' ',txt)
    txt=re.sub(r'\\n{3,}','\\n\\n',txt)
    alpha=sum(ch.isalpha() for ch in txt)
    if alpha>80:
        pages.append(txt.strip())
full='\\n\\n--- STREAM BREAK ---\\n\\n'.join(pages)
out_path.write_text(full, encoding='utf-8')
print(out_path)
print(len(full), 'chars')
