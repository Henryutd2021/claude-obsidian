filters:
  and:
    - file.ext == "md"
views:
  - type: table
    name: Subdomain hubs
    filters:
      and:
        - file.inFolder("wiki/subdomains")
    order:
      - file.name
    limit: 50
  - type: table
    name: Pattern pages
    filters:
      and:
        - file.inFolder("wiki/patterns")
    order:
      - file.name
    limit: 200
  - type: table
    name: Bank pages
    filters:
      and:
        - file.inFolder("wiki/banks")
    order:
      - file.name
    limit: 100
  - type: table
    name: Bridge pages
    filters:
      and:
        - file.inFolder("wiki/bridges")
    order:
      - file.name
    limit: 100
  - type: table
    name: Playbook pages
    filters:
      and:
        - file.inFolder("wiki/playbook")
    order:
      - file.name
    limit: 100
  - type: table
    name: Folder-about navigation
    filters:
      and:
        - file.name == "_about"
    order:
      - file.name
    limit: 50
