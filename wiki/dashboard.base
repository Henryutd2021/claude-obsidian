filters:
  and:
    - file.ext == "md"
formulas:
  age_days: (now() - file.mtime).days
properties:
  type:
    displayName: Type
  title:
    displayName: Title
  status:
    displayName: Status
  updated:
    displayName: Updated
  tags:
    displayName: Tags
  formula.age_days:
    displayName: Days Since Edit
views:
  - type: table
    name: Subdomain hubs
    filters:
      and:
        - file.inFolder("wiki/subdomains")
    order:
      - file.name
      - title
      - status
      - updated
      - formula.age_days
    limit: 50
  - type: table
    name: Pattern pages
    filters:
      and:
        - file.inFolder("wiki/patterns")
    order:
      - file.name
      - type
      - title
      - status
      - formula.age_days
    limit: 200
  - type: table
    name: Bank pages
    filters:
      and:
        - file.inFolder("wiki/banks")
    order:
      - file.name
      - type
      - title
      - status
      - formula.age_days
    limit: 100
  - type: table
    name: Bridge pages
    filters:
      and:
        - file.inFolder("wiki/bridges")
    order:
      - file.name
      - title
      - status
      - formula.age_days
    limit: 100
  - type: table
    name: Playbook pages
    filters:
      and:
        - file.inFolder("wiki/playbook")
    order:
      - file.name
      - type
      - title
      - status
      - formula.age_days
    limit: 100
  - type: table
    name: Folder-about navigation
    filters:
      and:
        - file.name == "_about"
    order:
      - file.name
      - title
      - status
    limit: 50
