filters:
  and:
    - file.inFolder("wiki/papers")
    - file.ext == "md"
formulas:
  age_days: (now() - file.mtime).days
properties:
  zotero_key:
    displayName: Zotero
  journal:
    displayName: Journal
  year:
    displayName: Year
  paper_type:
    displayName: Type
  main_contribution:
    displayName: Contribution
  method_type:
    displayName: Method
  topic:
    displayName: Topic
  journal_role:
    displayName: Role
  ingest_depth:
    displayName: Depth
  subdomain_primary:
    displayName: Subdomain (primary)
  subdomain_secondary:
    displayName: Subdomain (bridges)
  relevance_to_my_research:
    displayName: Relevance
  ingest_status:
    displayName: Status
  address:
    displayName: Addr
  formula.age_days:
    displayName: Days Since Edit
views:
  - type: table
    name: All papers
    order:
      - file.name
      - year
      - journal
      - journal_role
      - ingest_depth
      - subdomain_primary
      - main_contribution
      - relevance_to_my_research
      - ingest_status
    sort:
      - property: year
        direction: DESC
      - property: journal_role
        direction: ASC
    limit: 300
  - type: table
    name: L1 top-journal exemplars
    filters:
      and:
        - journal_role == "top_journal_exemplar"
    order:
      - file.name
      - year
      - journal
      - subdomain_primary
      - main_contribution
      - relevance_to_my_research
    sort:
      - property: year
        direction: DESC
    limit: 200
  - type: table
    name: L2 applied (deep)
    filters:
      and:
        - journal_role == "applied_flagship"
        - ingest_depth == "A_deep"
    order:
      - file.name
      - year
      - journal
      - subdomain_primary
      - main_contribution
    sort:
      - property: year
        direction: DESC
    limit: 200
  - type: table
    name: L2 applied (medium)
    filters:
      and:
        - journal_role == "applied_flagship"
        - ingest_depth == "B_medium"
    order:
      - file.name
      - year
      - journal
      - subdomain_primary
      - main_contribution
    sort:
      - property: year
        direction: DESC
    limit: 200
  - type: card
    name: By subdomain (primary)
    groupBy:
      property: subdomain_primary
      direction: ASC
    order:
      - file.name
      - year
      - journal
      - journal_role
      - ingest_depth
    limit: 300
  - type: card
    name: By archetype (L1 only)
    filters:
      and:
        - journal_role == "top_journal_exemplar"
    groupBy:
      property: main_contribution
      direction: ASC
    order:
      - file.name
      - year
      - journal
  - type: table
    name: Bridges activity
    filters:
      and:
        - subdomain_secondary != null
    order:
      - file.name
      - year
      - subdomain_primary
      - subdomain_secondary
      - journal_role
    limit: 300
  - type: list
    name: Drafts (need review)
    filters:
      and:
        - ingest_status == "draft"
    order:
      - file.name
      - formula.age_days
  - type: list
    name: High-relevance backlog
    filters:
      and:
        - relevance_to_my_research == "high"
        - ingest_status != "reviewed"
    order:
      - file.name
      - year
      - journal_role
  - type: list
    name: Upgrade candidates (L2-A flagged for L1 re-ingest)
    filters:
      and:
        - journal_role == "applied_flagship"
        - ingest_depth == "A_deep"
        - tags.contains("flagged-for-l1-promotion")
    order:
      - file.name
      - year
      - subdomain_primary
